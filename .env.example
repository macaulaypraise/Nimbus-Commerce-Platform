# =============================================================================
# Nimbus Commerce Platform — Environment Configuration
# =============================================================================
# Copy to .env and fill in real values:
#     cp .env.example .env
#
# Rules:
#   • Never commit a populated .env.
#   • Production / staging populate these vars via their secret manager
#     (AWS Secrets Manager, HashiCorp Vault, k8s Secret, etc.). No real
#     value should ever live in this file or in version control.
#   • The "test" environment uses .env.test instead; see .env.test.example.
# =============================================================================

# --- Runtime environment -----------------------------------------------------
# One of: development | staging | production | test
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
# LOG_JSON unset => JSON in production/staging, colored console elsewhere.
# Force a specific format by setting LOG_JSON=true or LOG_JSON=false.

# --- App metadata -------------------------------------------------------------
APP_NAME=nimbus
APP_VERSION=0.1.0
# CORS_ORIGINS is a comma-separated list. Empty disables CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Database (PostgreSQL) ---------------------------------------------------
# Use the asyncpg driver explicitly. The asyncpg URL is required; the
# psycopg2 URL will not work with our async SQLAlchemy engine.
DATABASE_URL=postgresql+asyncpg://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/CHANGE_ME_DB_NAME
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_ECHO=false

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT_SECONDS=5

# --- Kafka --------------------------------------------------------------------
# Comma-separated list of bootstrap servers.
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_CONSUMER_GROUP=nimbus
KAFKA_REQUEST_TIMEOUT_MS=30000

# --- Security ----------------------------------------------------------------
# Used by the gateway module for password hashing (argon2) and JWT signing.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_64_BYTE_URLSAFE_RANDOM_VALUE
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# --- Observability ------------------------------------------------------------
# OTLP endpoint for traces and metrics. Leave empty to disable.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=nimbus
SENTRY_DSN=
