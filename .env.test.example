# =============================================================================
# Nimbus Commerce Platform — TEST Environment Configuration
# =============================================================================
# Copy to .env.test for local pytest runs:
#     cp .env.test.example .env.test
#
# This file IS safe to commit. The test isolation guard in
# tests/conftest.py will REFUSE to run if any value here points at a
# production-like host. In particular:
#   • The database name MUST contain "test".
#   • The Redis URL MUST use a non-zero database number.
#   • The host MUST be localhost, 127.0.0.1, or a docker-compose service
#     name (e.g., postgres, redis, kafka).
#
# If you have no .env.test file, conftest.py provides the same defaults
# via os.environ.setdefault() so tests run out of the box.
# =============================================================================

ENVIRONMENT=test
DEBUG=false
LOG_LEVEL=WARNING
LOG_JSON=false

APP_NAME=nimbus-test
APP_VERSION=0.1.0
CORS_ORIGINS=

# Local docker-compose PostgreSQL. Database name is 'nimbus_test' —
# the conftest guard verifies the substring 'test' is present.
TEST_DATABASE_URL=postgresql+asyncpg://nimbus:nimbus@127.0.0.1:5432/nimbus_test
DATABASE_POOL_SIZE=2
DATABASE_MAX_OVERFLOW=4
DATABASE_POOL_TIMEOUT_SECONDS=5
DATABASE_ECHO=false

# Local docker-compose Redis on db=1 (db=0 would be unsafe).
TEST_REDIS_URL=redis://127.0.0.1:6379/1
REDIS_MAX_CONNECTIONS=5
REDIS_SOCKET_TIMEOUT_SECONDS=2

# Local docker-compose Kafka (single-node KRaft).
TEST_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_CONSUMER_GROUP=nimbus-test
KAFKA_REQUEST_TIMEOUT_MS=10000

# A fixed SECRET_KEY is acceptable in tests as long as ENVIRONMENT=test.
SECRET_KEY=test-secret-key-not-for-production-do-not-use-anywhere-else-1234567890
ARGON2_TIME_COST=1
ARGON2_MEMORY_COST=8192
ARGON2_PARALLELISM=1
